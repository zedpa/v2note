{
  "sections": [
    {
      "title": "通用",
      "key": "general",
      "fields": [
        {
          "key": "theme",
          "label": "主题",
          "type": "select",
          "options": ["system", "light", "dark"],
          "default": "system"
        },
        {
          "key": "language",
          "label": "语言",
          "type": "select",
          "options": ["zh-CN", "en-US"],
          "default": "zh-CN",
          "disabled": true
        }
      ]
    },
    {
      "title": "日报",
      "key": "daily",
      "fields": [
        {
          "key": "morningBriefingHour",
          "label": "早报时间",
          "type": "number",
          "default": 6,
          "min": 4,
          "max": 12,
          "suffix": "点"
        },
        {
          "key": "eveningSummaryHour",
          "label": "晚报时间",
          "type": "number",
          "default": 22,
          "min": 18,
          "max": 23,
          "suffix": "点"
        },
        {
          "key": "dailyNotifications",
          "label": "日报推送通知",
          "type": "toggle",
          "default": true
        }
      ]
    },
    {
      "title": "录音",
      "key": "recording",
      "fields": [
        {
          "key": "asrMode",
          "label": "语音识别模式",
          "type": "select",
          "options": ["realtime", "upload"],
          "optionLabels": ["实时识别（快速，准确率较低）", "录后识别（较慢，准确率更高）"],
          "default": "realtime"
        },
        {
          "key": "quickCaptureNotification",
          "label": "通知栏快捷录入",
          "type": "toggle",
          "default": true
        },
        {
          "key": "floatingBubble",
          "label": "悬浮录入气泡",
          "type": "toggle",
          "default": false
        },
        {
          "key": "iosShortcutGuide",
          "label": "iOS 快捷指令配置",
          "type": "info",
          "description": "打开「快捷指令」App → 搜索「念念」→ 可将「念念录一条」绑定到 Action Button 或添加到锁屏 Widget",
          "platform": "ios"
        }
      ]
    },
    {
      "title": "AI 提醒",
      "key": "proactive",
      "fields": [
        {
          "key": "proactiveInterval",
          "label": "提醒检查间隔 (分钟)",
          "type": "number",
          "default": 30,
          "min": 5,
          "max": 120
        }
      ]
    }
  ]
}
