{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/inject-spec-reminder.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/load-spec-template.sh" },
          { "type": "command", "command": ".claude/hooks/check-spec-read.sh" },
          { "type": "command", "command": ".claude/hooks/check-e2e-first.sh" },
          { "type": "command", "command": ".claude/hooks/load-pitfalls.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/check-fix-backport.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\" && .claude/hooks/on-stop.sh'" }
        ]
      }
    ]
  }
}
